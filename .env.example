# ============================================================================
# Pitwall IQ — environment configuration (root reference)
# Copy the relevant blocks into backend/.env and frontend/.env.local.
# NOTHING here is required for the app to run on open F1 data.
# Secrets (F1 TV token, LLM key) are read ONLY by the backend and are never
# exposed to the browser.
# ============================================================================

# ---------------------------------------------------------------------------
# BACKEND  (backend/.env)
# ---------------------------------------------------------------------------

# Force the realistic simulated demo race instead of fetching live data.
# Handy for demos, offline dev, or when F1 hosts are blocked by a network policy.
PITWALL_IQ_MOCK_MODE=false

# Try real pitwall/FastF1 data first (recommended). Set false to stay fully offline.
PITWALL_IQ_ENABLE_LIVE=true

# Use FastF1 (richer laps/telemetry) when available. Requires f1pitwall[full].
PITWALL_IQ_USE_FASTF1=true

# Seconds before a single upstream fetch gives up.
PITWALL_IQ_FETCH_TIMEOUT=30

# Where normalized real sessions are cached on disk.
PITWALL_IQ_CACHE_DIR=backend/data/cache
PITWALL_IQ_CACHE_TTL_HOURS=720

# Default season shown first in the UI.
PITWALL_IQ_DEFAULT_YEAR=2026

# Comma-separated allowed CORS origins (the frontend URL).
PITWALL_IQ_CORS=http://localhost:3000

# --- OPTIONAL secrets (server-side only) ---

# F1 TV Premium token — ONLY needed for live car telemetry/GPS during a live
# session. The whole app works without it on open/free data. Never sent to the client.
# F1TV_TOKEN=

# LLM key — OPTIONAL. If set, natural-language answers may be polished for wording.
# The facts always come from the deterministic engine; no key is ever required.
# ANTHROPIC_API_KEY=
# PITWALL_IQ_LLM_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# FRONTEND  (frontend/.env.local)
# ---------------------------------------------------------------------------

# Base URL of the backend API. Inlined at build time (safe, non-secret).
NEXT_PUBLIC_API_BASE=http://localhost:8000
