{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pitwall IQ",
  "version": "2.0.0",
  "identifier": "com.pitwalliq.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pitwall IQ",
        "width": 1440,
        "height": 940,
        "minWidth": 1024,
        "minHeight": 700,
        "visible": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "identifier": "com.pitwalliq.app",
    "category": "Sports",
    "shortDescription": "F1 race intelligence",
    "longDescription": "Pitwall IQ — explore why an F1 race unfolded the way it did: strategy, pace, tyres, pit stops and plain-English answers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
